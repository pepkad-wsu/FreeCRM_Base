    // ========================================================
    // Selections for DevOps Projects, Repositories, and Branches
    // ========================================================
    protected string SelectedProjectId { get; set; } = "";
    protected DataObjects.DevopsProjectInfo? SelectedProjectInfo => WsuEitOrgInfo?.Projects.FirstOrDefault(p => p.ProjectId == SelectedProjectId);
    protected string SelectedRepoId { get; set; } = "";
    protected DataObjects.DevopsGitRepoInfo? SelectedRepoInfo => SelectedProjectInfo?.GitRepos.FirstOrDefault(r => r.RepoId == SelectedRepoId);
    protected string SelectedBranch { get; set; } = "";
    protected DataObjects.DevopsGitRepoBranchInfo? SelectedBranchInfo => SelectedRepoInfo?.GitBranches.FirstOrDefault(r => r.BranchName == SelectedBranch);
    protected Dictionary<string, DataObjects.DevopsVariableGroup> SelectedEnviornmentVariableGroups { get; set; } = new();

    // ========================================================
    // Pipeline Data Properties
    // ========================================================
    protected List<DataObjects.DevopsPipelineDefinition> ReleasePipelinesList { get; set; } = new List<DataObjects.DevopsPipelineDefinition>();
    protected int SelectedPipelineId { get; set; } = 0;
    protected DataObjects.DevopsPipelineDefinition? SelectedPipelineInfo => ReleasePipelinesList?.FirstOrDefault(p => p.Id == SelectedPipelineId);
    protected string ExistingYamlContent { get; set; } = "";
    private string NewVariableGroupName = "";
    private string NewVariableGroupDescription = "";
    private string NewVariableGroupVariablesJson = "{}";

    // Properties for new variable group creation:
    List<DataObjects.DevopsVariable> NewVariables { get; set; } = new List<DataObjects.DevopsVariable>();

    // Property for editing an existing variable group:
    DataObjects.DevopsVariableGroup EditingVariableGroup { get; set; } = new DataObjects.DevopsVariableGroup { Variables = new List<DataObjects.DevopsVariable>() };

    void AddVariable()
    {
        NewVariables.Add(new DataObjects.DevopsVariable());
        StateHasChanged();
    }

    void RemoveVariable(DataObjects.DevopsVariable variable)
    {
        NewVariables.Remove(variable);
        StateHasChanged();
    }

    void AddEditingVariable()
    {
        if (EditingVariableGroup.Variables == null)
        {
            EditingVariableGroup.Variables = new List<DataObjects.DevopsVariable>();
        }
        EditingVariableGroup.Variables.Add(new DataObjects.DevopsVariable());
        StateHasChanged();
    }

    void RemoveEditingVariable(DataObjects.DevopsVariable variable)
    {
        EditingVariableGroup.Variables.Remove(variable);
        StateHasChanged();
    }

    void OnVariableGroupChanged(DataObjects.EnvSetting env, ChangeEventArgs e)
    {
        // When the dropdown changes, update the env's VariableGroupName.
        string selected = e.Value?.ToString() ?? "";
        env.VariableGroupName = selected;
        if (!string.IsNullOrEmpty(selected))
        {
            // Load the existing group for editing
            EditingVariableGroup = WsuEitOrgInfo?.DevopsVariableGroups.FirstOrDefault(v => v.Name == selected)
                                    ?? new DataObjects.DevopsVariableGroup { Name = selected, Variables = new List<DataObjects.DevopsVariable>() };
        }
        else
        {
            // If no group is selected, clear the editing group.
            EditingVariableGroup = new DataObjects.DevopsVariableGroup { Variables = new List<DataObjects.DevopsVariable>() };
        }
        StateHasChanged();
    }

    async Task CreateNewVariableGroup(DataObjects.EnvSetting env)
    {
        try
        {
            var newGroup = new DataObjects.DevopsVariableGroup
                {
                    Name = NewVariableGroupName,
                    Description = NewVariableGroupDescription,
                    Variables = NewVariables
                };

            var response = await Http.PostAsJsonAsync(DataObjects.Endpoints.ReleasePipelines.CreateVariableGroup, newGroup);
            if (response.IsSuccessStatusCode)
            {
                var createdGroup = await response.Content.ReadFromJsonAsync<DataObjects.DevopsVariableGroup>();
                if (WsuEitOrgInfo != null && createdGroup != null)
                {
                    WsuEitOrgInfo.DevopsVariableGroups.Add(createdGroup);
                }
                // Set the env's variable group to the newly created group.
                env.VariableGroupName = createdGroup?.Name;
                // Clear the creation fields.
                NewVariableGroupName = "";
                NewVariableGroupDescription = "";
                NewVariables.Clear();
                Model.Message_Saved("Variable group created successfully.");
            }
            else
            {
                Model.ErrorMessages(new List<string> { "Error creating variable group: " + await response.Content.ReadAsStringAsync() });
            }
        }
        catch (Exception ex)
        {
            Model.ErrorMessages(new List<string> { "Exception in CreateNewVariableGroup: " + ex.Message });
        }
        StateHasChanged();
    }

    async Task SaveEditedVariableGroup()
    {
        try
        {
            // Post the updated group to the API for saving.
            var response = await Http.PostAsJsonAsync(DataObjects.Endpoints.ReleasePipelines.UpdateVariableGroup, EditingVariableGroup);
            if (response.IsSuccessStatusCode)
            {
                var updatedGroup = await response.Content.ReadFromJsonAsync<DataObjects.DevopsVariableGroup>();
                if (updatedGroup != null)
                {
                    // Update the list in your global DevOps org info.
                    var index = WsuEitOrgInfo.DevopsVariableGroups.FindIndex(v => v.Id == updatedGroup.Id);
                    if (index >= 0)
                    {
                        WsuEitOrgInfo.DevopsVariableGroups[index] = updatedGroup;
                    }
                    Model.Message_Saved("Variable group updated successfully.");
                }
            }
            else
            {
                Model.ErrorMessages(new List<string> { "Failed to update variable group: " + await response.Content.ReadAsStringAsync() });
            }
        }
        catch (Exception ex)
        {
            Model.ErrorMessages(new List<string> { "Error updating variable group: " + ex.Message });
        }
        StateHasChanged();
    }

    async Task OnPipelineChanged(ChangeEventArgs e)
    {
        try
        {
            if (int.TryParse(e.Value?.ToString(), out int pid))
            {
                SelectedPipelineId = pid;
                var pipeline = ReleasePipelinesList.FirstOrDefault(p => p.Id == SelectedPipelineId);
                if (pipeline != null && !string.IsNullOrEmpty(pipeline.YamlFileName))
                {
                    await LoadReleasePipelineYaml(pipeline.YamlFileName);
                }
                else
                {
                    SelectedPipelineId = 0;
                    ExistingYamlContent = "";
                    EditableYamlContent = "";
                }
            }
            else
            {
                SelectedPipelineId = 0;
                ExistingYamlContent = "";
                EditableYamlContent = "";
            }
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error in OnPipelineChanged: " + ex.Message);
        }
    }

    private async Task LoadReleasePipelinesAsync()
    {
        try
        {
            ReleasePipelinesList = await Http.GetFromJsonAsync<List<DataObjects.DevopsPipelineDefinition>>(DataObjects.Endpoints.ReleasePipelines.GetPipelines)
                            ?? new List<DataObjects.DevopsPipelineDefinition>();
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error loading release pipelines: " + ex.Message);
        }

    }

    private async Task LoadReleasePipelineYaml(string filePath)
    {
        try
        {
            ExistingYamlContent = await Http.GetStringAsync(DataObjects.Endpoints.ReleasePipelines.GetYmlFileContent + "?filePath=" + Uri.EscapeDataString(filePath));
            EditableYamlContent = ExistingYamlContent;
            // Update the Monaco editor with the loaded content
            if (_monacoEditorDevOps != null)
            {
                await _monacoEditorDevOps.SetValue(EditableYamlContent);
            }
            Console.WriteLine("Loaded pipeline YAML successfully.");
        }
        catch (Exception ex)
        {
            ExistingYamlContent = "";
            EditableYamlContent = "";
            Console.WriteLine("Error loading pipeline YAML: " + ex.Message);
        }
        StateHasChanged();
    }

    // ========================================================
    // New Pipeline Creation UI State & Methods
    // ========================================================
    private string NewPipelineName = "";
    private bool IsCreatingPipelineLoading = false;

    protected async Task SubmitNewPipeline()
    {
        // Clear any previous messages
        Model.ClearMessages();

        // Validate required fields
        if (string.IsNullOrWhiteSpace(NewPipelineName))
        {
            Model.ErrorMessages(new List<string> { "Pipeline name is required." });
            return;
        }
        if (string.IsNullOrWhiteSpace(SelectedProjectId) || string.IsNullOrWhiteSpace(SelectedRepoId) || string.IsNullOrWhiteSpace(SelectedBranch))
        {
            Model.ErrorMessages(new List<string> { "Project, repository and branch must be selected before creating a pipeline." });
            return;
        }

        try
        {
            IsCreatingPipelineLoading = true;
            var projectName = SelectedProjectInfo.ProjectName.Replace(" ", "");
            var request = new DataObjects.PipelineCreationRequest
                {
                    Name = NewPipelineName,
                    ProjectName = projectName,
                    ProjectId = SelectedProjectId,
                    RepositoryId = SelectedRepoId,
                    DefaultBranch = SelectedBranch,
                    YamlFilePath = $"/projects/{projectName}/" + NewPipelineName.Replace(" ", "") + ".yml"
                };

            // Indicate that the creation is in progress.
            Model.Message_Saving("Creating pipeline...");

            var response = await Http.PostAsJsonAsync(DataObjects.Endpoints.ReleasePipelines.CreatePipeline, request);

            // Clear saving message once API call is complete.
            Model.ClearMessages();

            if (response.IsSuccessStatusCode)
            {
                var createdPipeline = await response.Content.ReadFromJsonAsync<DataObjects.BuildDefinition>();
                await LoadReleasePipelinesAsync();
                if (createdPipeline != null)
                {
                    SelectedPipelineId = createdPipeline.Id;
                    await OnPipelineChanged(new ChangeEventArgs { Value = createdPipeline.Id.ToString() });
                }
                Model.Message_Saved("Pipeline created successfully.");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Model.ErrorMessages(new List<string> { "Error creating pipeline: " + error });
            }
        }
        catch (Exception ex)
        {
            Model.ErrorMessages(new List<string> { "Exception creating pipeline: " + ex.Message });
        }
        finally
        {
            IsCreatingPipelineLoading = false;
            StateHasChanged();
        }
    }


