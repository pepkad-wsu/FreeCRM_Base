@page "/devops"
@page "/{TenantCode}/devops"
@using System.Text.Json
@inject BlazorDataModel Model
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager NavManager

@implements IDisposable

<!-- Inline CSS for wizard styling -->
<style>
    .wizard-tab-content {
    margin-top: 20px;
    }

    .wizard-navigation {
    margin-bottom: 20px;
    }

    .disabled-tab {
    pointer-events: none;
    opacity: 0.5;
    }

    .card-footer {
    background-color: #f8f9fa;
    }

    .editor-container {
    height: calc(100vh - 300px);
    border: 1px solid #ddd;
    overflow: auto;
    padding: 10px;
    background-color: #f8f9fa;
    }

    .nav-tabs .nav-link.active {
    font-weight: bold;
    }

    .card-header span.version-label {
    font-size: 0.9rem;
    color: #555;
    }
</style>

<!-- Loading indicator -->
@if (IsLoading)
{
    <div class="d-flex justify-content-center my-3">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}

@if (!IsLoading && Model.Loaded && Model.View == _pageName)
{

   

}

<!-- IIS Info Section (visible only for App Admins) -->
@if (Model?.User != null && Model.User.AppAdmin)
{
    <hr />
    <h3>IIS Information</h3>
    @if (IsLoadingIIS)
    {
        <div>Loading IIS Info...</div>
    }
    else if (IisInfoData == null || IisInfoData.Count == 0)
    {
        <div>No IIS Info data available.</div>
    }
    else
    {
        <ul class="nav nav-tabs" role="tablist">
            @foreach (var key in IisInfoData.Keys)
            {
                <li class="nav-item" role="presentation">
                    <button class=@("nav-link " + (SelectedIisTab == key ? "active" : ""))
                            @onclick="() => OnTabChanged(key)"
                            type="button">
                        @key
                    </button>
                </li>
            }
        </ul>
        <div class="tab-content mt-3">
            @foreach (var kvp in IisInfoData)
            {
                <div class=@("tab-pane " + (SelectedIisTab == kvp.Key ? "active" : "d-none"))>
                    <button class="btn btn-sm btn-secondary mb-2" @onclick="() => ToggleIisExpandView(kvp.Key)">
                        @(IsJsonExpanded.ContainsKey(kvp.Key) && IsJsonExpanded[kvp.Key] ? "Collapse" : "Expand")
                    </button>
                    <div class="json-container" style="background-color: #f8f9fa; padding: 10px; border: 1px solid #ddd; border-radius: 4px; @(IsJsonExpanded.ContainsKey(kvp.Key) && IsJsonExpanded[kvp.Key] ? "" : "max-height: 400px; overflow-y: auto;")">
                        <pre>@JsonSerializer.Serialize(kvp.Value, new JsonSerializerOptions { WriteIndented = true })</pre>
                    </div>
                </div>
            }
        </div>
    }
}

@code {
    private Dictionary<string, DataObjects.VariableGroupEditState> variableGroupStates = new();

    // New property for .csproj file selection
    protected string SelectedCsprojPath { get; set; } = "";

    // Monaco Editor reference for the YAML editor
    private MonacoEditor _monacoEditorDevOps = null!;

    protected string _monacoContent = "";
    protected string _monacoContentToDiff = "";
    protected bool _monacoReadOnly = false;

    // ========================================================
    // Azure DevOps Integration Properties
    // ========================================================
    protected string Organization { get; set; } = "wsueit";
    protected DataObjects.DevopsOrgInfo? WsuEitOrgInfo { get; set; }
    protected bool IsLoading { get; set; } = true;
    protected bool IsLoadingIIS { get; set; } = true;

    // ========================================================
    // IIS Information Section Properties
    // ========================================================
    protected Dictionary<string, DataObjects.IISInfo?>? IisInfoData { get; set; }
