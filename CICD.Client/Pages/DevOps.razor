    // Navigation methods
    private void NavigateToStep(int stepIndex)
    {
        // Allow backward navigation, but prevent forward jumps
        if (stepIndex <= currentStep)
        {
            currentStep = stepIndex;
            StateHasChanged();
        }
    }

    private void NextStep()
    {
        if (currentStep < StepNames.Length - 1)
        {
            currentStep++;
            StateHasChanged();
        }
    }

    private void PrevStep()
    {
        if (currentStep > 0)
        {
            currentStep--;
            StateHasChanged();
        }
    }

