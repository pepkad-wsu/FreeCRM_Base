    private async Task LoadIisInfoAsync()
    {
        try
        {
            IisInfoData = await Helpers.GetOrPost<Dictionary<string, DataObjects.IISInfo?>>(DataObjects.Endpoints.DevOps.GetIISInfo);
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error loading IIS Info: " + ex.Message);
