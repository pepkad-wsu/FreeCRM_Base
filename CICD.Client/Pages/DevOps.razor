    void RemoveEnv(int index)
    {
        if (index < 0 || index >= EnvSettingsList.Count) return;
        EnvSettingsList.RemoveAt(index);
        StateHasChanged();
    }

    void MoveEnvUp(int index)
    {
        if (index <= 0 || index >= EnvSettingsList.Count) return;
        var temp = EnvSettingsList[index - 1];
        EnvSettingsList[index - 1] = EnvSettingsList[index];
        EnvSettingsList[index] = temp;
        StateHasChanged();
    }

    void MoveEnvDown(int index)
    {
        if (index < 0 || index >= EnvSettingsList.Count - 1) return;
        var temp = EnvSettingsList[index + 1];
        EnvSettingsList[index + 1] = EnvSettingsList[index];
        EnvSettingsList[index] = temp;
        StateHasChanged();
    }

