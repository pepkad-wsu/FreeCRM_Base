    private async Task LoadDevopsInfoAsync()
    {
        int attempts = 0;
        while (attempts < 10)
        {
            try
            {
                IsLoading = true;
                WsuEitOrgInfo = await Http.GetFromJsonAsync<DataObjects.DevopsOrgInfo>(DataObjects.Endpoints.DevOps.GetWsuEitOrgInfo);
                if (WsuEitOrgInfo != null && WsuEitOrgInfo.Projects != null && WsuEitOrgInfo.Projects.Any())
                {
                    Console.WriteLine("Loaded DevOps Info successfully.");
                    break;
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error loading DevOps Info: {ex.Message}");
            }

            attempts++;
            await Task.Delay(3000);
        }
    }

