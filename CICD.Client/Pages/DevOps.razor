    // Helper to get (or create) an environment settings instance
    private DataObjects.EnvSetting GetEnvSetting(string envKey)
    {
        var setting = EnvSettingsList.FirstOrDefault(e => e.EnvName.Equals(envKey, StringComparison.OrdinalIgnoreCase));
        if (setting == null)
        {

            var dev = "azuredev.em.wsu.edu";
            var prod = "prod.em.wsu.edu";
            var cms = "cms.em.wsu.edu";
            var websiteNameDefault = "";
            switch (envKey)
            {
                case "DEV":
                    websiteNameDefault = dev;
                    break;
                case "PROD":
                    websiteNameDefault = prod;
                    break;
                case "CMS":
                    websiteNameDefault = cms;
                    break;
                default:
                    break;
            }

            setting = new DataObjects.EnvSetting
                {
                    EnvName = envKey,
                    IISDeploymentType = "IISWebApplication",
                    WebsiteName = "" + websiteNameDefault,
                    VirtualPath = "/" + SelectedProjectInfo?.ProjectName?.ToLower(),
                    AppPoolName = "" + websiteNameDefault + "." + SelectedProjectInfo?.ProjectName?.ToLower(),
                    VariableGroupName = SelectedProjectInfo?.ProjectName?.ToLower().Replace(" ", "") + "_appsettings_" + envKey
                };

            if (string.IsNullOrWhiteSpace(setting.VirtualPath))
                if (string.IsNullOrWhiteSpace(setting.VariableGroupName))
                {
                    setting.VariableGroupName = string.Empty + SelectedProjectInfo?.ProjectName + "_appsettings_" + envKey;
                }
            EnvSettingsList.Add(setting);
        }
        return setting;
    }

    // Invokes the variable group creation for a specific environment
    private async Task CreateVariableGroupForEnv(string envKey)
    {
        var env = GetEnvSetting(envKey);
        await CreateNewVariableGroup(env);
    }

